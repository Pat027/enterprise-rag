# LLM provider — OpenRouter (default; OpenAI-compatible gateway to many models)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Safety layer — OpenAI Moderation (free)
OPENAI_API_KEY=sk-...

# Safety layer — LlamaGuard 3 via Groq (sub-100ms, fractions of a cent)
GROQ_API_KEY=gsk_...
GROQ_LLAMAGUARD_MODEL=llama-guard-3-8b

# Safety layer — Constitutional critic via Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CRITIC_MODEL=claude-haiku-4-5-20251001

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# Embeddings + reranker (local via sentence-transformers; downloaded on first use)
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Safety toggles (all on by default)
SAFETY_OPENAI_MODERATION=true
SAFETY_LLAMAGUARD=true
SAFETY_CONSTITUTIONAL=true

# Retrieval
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# API
API_HOST=0.0.0.0
API_PORT=8000
