# ─── Hugging Face token (required to pull Llama models from HF) ───
# Both Llama 3.1 70B Instruct and Llama-Guard-3-8B are gated on HF.
# Accept the licenses at https://huggingface.co/meta-llama and create a token
# with read scope at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ─── vLLM endpoints (defaults match docker-compose.yml service names) ───
VLLM_GEN_URL=http://vllm-gen:8000/v1
VLLM_GEN_MODEL=neuralmagic/Meta-Llama-3.1-8B-Instruct-FP8-dynamic
VLLM_GUARD_URL=http://vllm-guard:8000/v1
VLLM_GUARD_MODEL=meta-llama/Llama-Guard-3-8B

# ─── OpenAI Moderation: free, optional, layer 1 of safety ───
# Leave blank to disable layer 1 (set SAFETY_OPENAI_MODERATION=false too).
OPENAI_API_KEY=sk-...

# ─── Vector store ───
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ─── Embeddings + reranker (run inside API container, GPU-accelerated) ───
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDER_DEVICE=cuda
RETRIEVAL_MODE=hybrid  # dense | bm25 | hybrid

# ─── Safety toggles (all on by default) ───
SAFETY_OPENAI_MODERATION=true
SAFETY_LLAMAGUARD=true
SAFETY_CONSTITUTIONAL=true

# ─── Retrieval ───
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# ─── API ───
API_HOST=0.0.0.0
API_PORT=8000

# ─── API auth (leave empty to disable; comma-separated keys) ───
# Example: API_KEYS=sk-alice-abc123,sk-bob-def456
# When empty, all callers are accepted (auth disabled; rate limit keyed by IP).
API_KEYS=

# ─── Rate limit (per caller, in-memory token bucket; single-process only) ───
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=10
